import React, { useState, useEffect } from 'react';
import {
  Box,
  Typography,
  Card,
  TextField,
  Button,
  Grid,
  TextareaAutosize,
  Alert,
  Divider,
  Chip,
} from '@mui/material';
import { useNavigate, useSearchParams } from 'react-router-dom';
import MainLayout from '../../components/Layout/MainLayout';
import DeviationTable from '../../components/Common/DeviationTable';
import { COLORS } from '../../styles/theme';
import EditIcon from '@mui/icons-material/Edit';
import SaveIcon from '@mui/icons-material/Save';

const QAInvestigations = () => {
  const navigate = useNavigate();
  const [searchParams] = useSearchParams();
  const editId = searchParams.get('edit');

  const [deviations, setDeviations] = useState([]);
  const [selectedDeviation, setSelectedDeviation] = useState(null);
  const [investigationNotes, setInvestigationNotes] = useState('');
  const [rootCauses, setRootCauses] = useState('');
  const [capas, setCapas] = useState('');
  const [isEditing, setIsEditing] = useState(!!editId);
  const [searchTerm, setSearchTerm] = useState('');

  useEffect(() => {
    const fetchDeviations = async () => {
      try {
        const response = await fetch('http://localhost:8000/deviations');
        const data = await response.json();
        setDeviations(data || []);
      } catch (err) {
        setDeviations([
          {
            id: 1,
            event: 'Temperature excursion in cold room',
            study: 'STUDY-001',
            date: '2024-01-15',
            severity: 'High',
            status: 'Open',
          },
        ]);
      }
    };

    fetchDeviations();
  }, []);

  const handleSelectDeviation = (id) => {
    const dev = deviations.find((d) => d.id === id);
    setSelectedDeviation(dev);
    setIsEditing(false);
    setInvestigationNotes('');
    setRootCauses('');
    setCapas('');
  };

  const handleStartInvestigation = () => {
    setIsEditing(true);
  };

  const handleSaveInvestigation = () => {
    // Save investigation data
    alert(`Investigation saved for deviation ${selectedDeviation.id}:
Investigation Notes: ${investigationNotes}
Root Causes: ${rootCauses}
CAPA: ${capas}`);
    setIsEditing(false);
  };

  const handleSubmitQAReview = () => {
    alert(`QA review submitted for deviation ${selectedDeviation.id}`);
    // In production, this would update the status to "Pending Approval"
  };

  const filteredDeviations = deviations.filter(
    (d) =>
      d.event.toLowerCase().includes(searchTerm.toLowerCase()) ||
      d.study.toLowerCase().includes(searchTerm.toLowerCase())
  );

  return (
    <MainLayout>
      {/* Header */}
      <Box sx={{ mb: 4 }}>
        <Typography variant="h4" sx={{ fontWeight: 700, mb: 1 }}>
          Investigation Management
        </Typography>
        <Typography variant="body2" sx={{ color: COLORS.textMuted }}>
          Manage root cause analysis and CAPA for deviations
        </Typography>
      </Box>

      <Grid container spacing={3}>
        {/* Left Side - Deviation Selection */}
        <Grid item xs={12} md={4}>
          <Card sx={{ padding: 3, height: '100%', overflow: 'auto', maxHeight: '80vh' }}>
            <Typography variant="h6" sx={{ fontWeight: 600, mb: 2 }}>
              Deviations to Investigate
            </Typography>

            <TextField
              fullWidth
              placeholder="Search..."
              size="small"
              value={searchTerm}
              onChange={(e) => setSearchTerm(e.target.value)}
              sx={{ mb: 2 }}
            />

            <Box sx={{ display: 'flex', flexDirection: 'column', gap: 1 }}>
              {filteredDeviations.length > 0 ? (
                filteredDeviations.map((dev) => (
                  <Card
                    key={dev.id}
                    onClick={() => handleSelectDeviation(dev.id)}
                    sx={{
                      padding: 2,
                      cursor: 'pointer',
                      border: selectedDeviation?.id === dev.id ? `2px solid ${COLORS.primaryButton}` : `1px solid ${COLORS.borderLight}`,
                      backgroundColor: selectedDeviation?.id === dev.id ? '#E3F2FD' : 'transparent',
                      transition: 'all 0.2s',
                      '&:hover': {
                        boxShadow: '0 2px 8px rgba(0,0,0,0.1)',
                      },
                    }}
                  >
                    <Typography variant="body2" sx={{ fontWeight: 600, mb: 0.5 }}>
                      DEV-{String(dev.id).padStart(4, '0')}
                    </Typography>
                    <Typography variant="caption" sx={{ display: 'block', mb: 1, color: COLORS.textMuted }}>
                      {dev.event}
                    </Typography>
                    <Chip label={dev.status} size="small" />
                  </Card>
                ))
              ) : (
                <Typography variant="body2" sx={{ color: COLORS.textMuted, textAlign: 'center', py: 2 }}>
                  No deviations found
                </Typography>
              )}
            </Box>
          </Card>
        </Grid>

        {/* Right Side - Investigation Form */}
        <Grid item xs={12} md={8}>
          {selectedDeviation ? (
            <Card sx={{ padding: 4 }}>
              {/* Header */}
              <Box sx={{ mb: 3, pb: 3, borderBottom: `2px solid ${COLORS.borderLight}` }}>
                <Box sx={{ display: 'flex', justifyContent: 'space-between', alignItems: 'start' }}>
                  <Box>
                    <Typography variant="h5" sx={{ fontWeight: 700, mb: 1 }}>
                      Investigation Form
                    </Typography>
                    <Typography variant="body2" sx={{ color: COLORS.textMuted }}>
                      DEV-{String(selectedDeviation.id).padStart(4, '0')} - {selectedDeviation.event}
                    </Typography>
                  </Box>
                  {!isEditing && (
                    <Button
                      variant="contained"
                      startIcon={<EditIcon />}
                      onClick={handleStartInvestigation}
                      sx={{ backgroundColor: COLORS.primaryButton }}
                    >
                      Start Investigation
                    </Button>
                  )}
                </Box>
              </Box>

              {/* Deviation Summary */}
              <Box sx={{ mb: 3, p: 2, backgroundColor: '#F5F7FA', borderRadius: 1 }}>
                <Grid container spacing={2}>
                  <Grid item xs={12} sm={6}>
                    <Typography variant="caption" sx={{ color: COLORS.textMuted }}>
                      Study
                    </Typography>
                    <Typography variant="body2" sx={{ fontWeight: 500 }}>
                      {selectedDeviation.study}
                    </Typography>
                  </Grid>
                  <Grid item xs={12} sm={6}>
                    <Typography variant="caption" sx={{ color: COLORS.textMuted }}>
                      Date Reported
                    </Typography>
                    <Typography variant="body2" sx={{ fontWeight: 500 }}>
                      {new Date(selectedDeviation.date).toLocaleDateString()}
                    </Typography>
                  </Grid>
                  <Grid item xs={12} sm={6}>
                    <Typography variant="caption" sx={{ color: COLORS.textMuted }}>
                      Severity
                    </Typography>
                    <Chip
                      label={selectedDeviation.severity}
                      size="small"
                      sx={{
                        backgroundColor:
                          selectedDeviation.severity === 'High'
                            ? '#FFEBEE'
                            : selectedDeviation.severity === 'Medium'
                            ? '#FFF3E0'
                            : '#E8F5E9',
                        color:
                          selectedDeviation.severity === 'High'
                            ? '#D32F2F'
                            : selectedDeviation.severity === 'Medium'
                            ? '#F57C00'
                            : '#388E3C',
                      }}
                    />
                  </Grid>
                </Grid>
              </Box>

              <Divider sx={{ my: 3 }} />

              {/* Investigation Fields */}
              {isEditing ? (
                <Box>
                  {/* Investigation Notes */}
                  <Box sx={{ mb: 3 }}>
                    <Typography variant="body2" sx={{ fontWeight: 600, mb: 1 }}>
                      Investigation Notes
                    </Typography>
                    <TextareaAutosize
                      minRows={4}
                      value={investigationNotes}
                      onChange={(e) => setInvestigationNotes(e.target.value)}
                      placeholder="Document all investigation findings, observations, and data..."
                      style={{
                        width: '100%',
                        padding: '12px',
                        borderRadius: '4px',
                        border: `1px solid ${COLORS.borderLight}`,
                        fontFamily: 'Roboto, sans-serif',
                        fontSize: '14px',
                        fontWeight: 500,
                      }}
                    />
                  </Box>

                  {/* Root Causes */}
                  <Box sx={{ mb: 3 }}>
                    <Typography variant="body2" sx={{ fontWeight: 600, mb: 1 }}>
                      Root Causes (one per line)
                    </Typography>
                    <TextareaAutosize
                      minRows={3}
                      value={rootCauses}
                      onChange={(e) => setRootCauses(e.target.value)}
                      placeholder="• Root cause 1&#10;• Root cause 2&#10;• Root cause 3"
                      style={{
                        width: '100%',
                        padding: '12px',
                        borderRadius: '4px',
                        border: `1px solid ${COLORS.borderLight}`,
                        fontFamily: 'Roboto, sans-serif',
                        fontSize: '14px',
                      }}
                    />
                  </Box>

                  {/* CAPA */}
                  <Box sx={{ mb: 3 }}>
                    <Typography variant="body2" sx={{ fontWeight: 600, mb: 1 }}>
                      Corrective and Preventive Actions (CAPA)
                    </Typography>
                    <TextareaAutosize
                      minRows={3}
                      value={capas}
                      onChange={(e) => setCapas(e.target.value)}
                      placeholder="Describe the corrective and preventive actions to be taken..."
                      style={{
                        width: '100%',
                        padding: '12px',
                        borderRadius: '4px',
                        border: `1px solid ${COLORS.borderLight}`,
                        fontFamily: 'Roboto, sans-serif',
                        fontSize: '14px',
                      }}
                    />
                  </Box>

                  {/* Buttons */}
                  <Box sx={{ display: 'flex', gap: 2, justifyContent: 'flex-end' }}>
                    <Button
                      variant="outlined"
                      onClick={() => setIsEditing(false)}
                    >
                      Cancel
                    </Button>
                    <Button
                      variant="contained"
                      startIcon={<SaveIcon />}
                      onClick={handleSaveInvestigation}
                      sx={{ backgroundColor: COLORS.primaryButton }}
                    >
                      Save Investigation
                    </Button>
                    <Button
                      variant="contained"
                      onClick={handleSubmitQAReview}
                      sx={{ backgroundColor: COLORS.approveButton }}
                    >
                      Submit for Approval
                    </Button>
                  </Box>
                </Box>
              ) : (
                <Box sx={{ textAlign: 'center', py: 4 }}>
                  <Typography variant="body1" sx={{ color: COLORS.textMuted, mb: 2 }}>
                    No investigation data yet. Click "Start Investigation" to begin.
                  </Typography>
                  <Button
                    variant="contained"
                    startIcon={<EditIcon />}
                    onClick={handleStartInvestigation}
                    sx={{ backgroundColor: COLORS.primaryButton }}
                  >
                    Start Investigation
                  </Button>
                </Box>
              )}
            </Card>
          ) : (
            <Card sx={{ padding: 4, textAlign: 'center' }}>
              <Typography variant="body1" sx={{ color: COLORS.textMuted }}>
                Select a deviation from the list to begin investigation
              </Typography>
            </Card>
          )}
        </Grid>
      </Grid>
    </MainLayout>
  );
};

export default QAInvestigations;
